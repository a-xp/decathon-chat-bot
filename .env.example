# Copy to .env and adjust.

# OpenAI-compatible chat-completions base URL (e.g. LM Studio).
OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# API key. LM Studio ignores it but the header must be present; any value works.
OPENAI_API_KEY=lm-studio

# Tool-capable chat model served by the endpoint.
OPENAI_MODEL=google/gemma-4-31b

# Embedding model id as loaded in LM Studio.
OPENAI_EMBED_MODEL=bge-m3

# How many catalog products to retrieve per search call.
PRODUCT_SEARCH_N=10

# Max tool-call rounds per chat turn (guards against model loops).
MAX_TOOL_ROUNDS=6

# Where the embedded Chroma vector store lives on disk.
CHROMA_PATH=./chroma_data

# How many texts to embed per /embeddings request.
EMBED_BATCH=64

# Request timeout in seconds.
OPENAI_TIMEOUT=120

# Language the bot replies in (e.g. English, French, Polish).
# Leave empty or "auto" to match whatever language the user writes in.
CHAT_LANGUAGE=auto

# HTTP port for the chat UI.
PORT=8000
