# Copy to .env and adjust.

# OpenAI-compatible chat-completions base URL (e.g. LM Studio).
OPENAI_BASE_URL=http://127.0.0.1:1234/v1

# API key. LM Studio ignores it but the header must be present; any value works.
OPENAI_API_KEY=lm-studio

# Model name served by the endpoint (main chat model).
OPENAI_MODEL=microsoft/phi-4

# Model that decides if a turn needs catalog search and rewrites the query
# + picks a category. Defaults to OPENAI_MODEL (reusing the chat model avoids
# LM Studio reloading models every turn). Set to a separate tool-capable
# small model only if your endpoint can keep both resident, e.g.:
# OPENAI_ROUTER_MODEL=nvidia/nemotron-3-nano-4b

# How many catalog products to inject as context per grounded turn.
PRODUCT_SEARCH_N=8

# Embedding model id as loaded in LM Studio (used by the vector index/query).
OPENAI_EMBED_MODEL=bge-m3

# Where the embedded Chroma vector store lives on disk.
CHROMA_PATH=./chroma_data

# How many texts to embed per /embeddings request.
EMBED_BATCH=64

# Request timeout in seconds.
OPENAI_TIMEOUT=120

# Language the bot replies in (e.g. English, French, Polish).
# Leave empty or "auto" to match whatever language the user writes in.
CHAT_LANGUAGE=auto

# HTTP port for the chat UI.
PORT=8000
